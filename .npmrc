engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false

# Supply-chain hardening — applied 2026-05-26 in response to ongoing
# Shai-Hulud / Mini Shai-Hulud / TeamPCP waves (active campaign throughout
# 2025-09 → 2026-05). See SECURITY.md "Supply-chain defense layers".

# Disable lifecycle scripts — primary execution vector in the original
# Shai-Hulud worm. This repo has no native compilation step.
ignore-scripts=true

# 7-day cooldown — refuse to install package versions published less than
# 10080 minutes (= 7 days) ago. pnpm 10.16+ minimumReleaseAge.
minimum-release-age=10080

# Audit floor: fail `pnpm audit` on high-or-critical advisories.
audit-level=high
