{
  "name": "mcp-guard",
  "version": "0.1.0",
  "description": "Defensive-first CLI for MCP server config scanning and LLM prompt-injection red-team harness",
  "type": "module",
  "license": "MIT",
  "private": true,
  "author": "tomohiro takada",
  "repository": {
    "type": "git",
    "url": "https://github.com/leagames0221-sys/mcp-guard"
  },
  "bin": {
    "mcp-guard": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "pnpm audit --audit-level=high",
    "mask:check": "tsx scripts/precommit_mask_check.ts",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "packageManager": "pnpm@11.0.8",
  "dependencies": {
    "commander": "^13.0.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
